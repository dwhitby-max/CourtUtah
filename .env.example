PORT=5000
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL=
JWT_SECRET=
ENCRYPTION_KEY=

# Google OAuth (auth + calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.replit.app/api/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://your-app.replit.app/api/calendar/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# Email (SMTP / SendGrid)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS (production only — leave blank for same-origin)
CORS_ORIGIN=

# Sentry Error Tracking (optional — leave blank to disable)
SENTRY_DSN=
