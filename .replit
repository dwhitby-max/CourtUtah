modules = ["nodejs-20"]
run = "bash start.sh"
entrypoint = "server/src/index.ts"

[nix]
channel = "stable-24_05"

[env]
PORT = "5000"
HOST = "0.0.0.0"
NODE_ENV = "development"

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "npm run build"]
run = ["bash", "start-production.sh"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[userenv]

[userenv.shared]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
